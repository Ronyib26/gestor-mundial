# Neon Postgres - pooled connection (para queries en runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DB?sslmode=require"

# Neon Postgres - direct connection (para migraciones de Prisma)
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Orígenes permitidos por CORS (vacío = permitir cualquiera, dev)
# En producción restringe a tu dominio: https://tu-app.vercel.app
CORS_ORIGIN=

PORT=4000
