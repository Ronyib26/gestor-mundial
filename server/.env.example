# Connection string Neon/Postgres
# For Neon pooler (recommended for serverless): use the pooled URL with ?sslmode=require
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# For local dev (Prisma migrate / Studio): NON-pooled / direct URL
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# Server port (only used when running standalone, not on Vercel)
PORT=4000

# CORS: comma-separated allowed origins (empty = allow all in dev)
CORS_ORIGIN=
